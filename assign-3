number = 12321  
temp = number
reversed_num = 0
if number < 0:
    print(number, "is not a palindrome number")
else:
    while temp > 0:
        digit = temp % 10            
        reversed_num = (reversed_num * 10) + digit  
        temp = temp // 10           
if number == reversed_num:
        print(number, "is a palindrome number")
    else:
        print(number, "is not a palindrome number")
